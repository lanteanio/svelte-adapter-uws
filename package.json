{
  "name": "svelte-adapter-uws",
  "version": "0.5.1",
  "publishConfig": {
    "tag": "latest"
  },
  "description": "SvelteKit adapter for uWebSockets.js - high-performance C++ HTTP server with built-in WebSocket support",
  "author": "Kevin Radziszewski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lanteanio/svelte-adapter-uws.git"
  },
  "homepage": "https://github.com/lanteanio/svelte-adapter-uws#readme",
  "bugs": {
    "url": "https://github.com/lanteanio/svelte-adapter-uws/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./upgrade-response": {
      "types": "./index.d.ts",
      "default": "./upgrade-response.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "default": "./client.js"
    },
    "./vite": {
      "types": "./vite.d.ts",
      "default": "./vite.js"
    },
    "./testing": {
      "types": "./testing.d.ts",
      "default": "./testing.js"
    },
    "./plugins/replay": {
      "types": "./plugins/replay/server.d.ts",
      "default": "./plugins/replay/server.js"
    },
    "./plugins/replay/client": {
      "types": "./plugins/replay/client.d.ts",
      "default": "./plugins/replay/client.js"
    },
    "./plugins/presence": {
      "types": "./plugins/presence/server.d.ts",
      "default": "./plugins/presence/server.js"
    },
    "./plugins/presence/client": {
      "types": "./plugins/presence/client.d.ts",
      "default": "./plugins/presence/client.js"
    },
    "./plugins/channels": {
      "types": "./plugins/channels/server.d.ts",
      "default": "./plugins/channels/server.js"
    },
    "./plugins/channels/client": {
      "types": "./plugins/channels/client.d.ts",
      "default": "./plugins/channels/client.js"
    },
    "./plugins/throttle": {
      "types": "./plugins/throttle/server.d.ts",
      "default": "./plugins/throttle/server.js"
    },
    "./plugins/ratelimit": {
      "types": "./plugins/ratelimit/server.d.ts",
      "default": "./plugins/ratelimit/server.js"
    },
    "./plugins/cursor": {
      "types": "./plugins/cursor/server.d.ts",
      "default": "./plugins/cursor/server.js"
    },
    "./plugins/cursor/client": {
      "types": "./plugins/cursor/client.d.ts",
      "default": "./plugins/cursor/client.js"
    },
    "./plugins/middleware": {
      "types": "./plugins/middleware/server.d.ts",
      "default": "./plugins/middleware/server.js"
    },
    "./plugins/queue": {
      "types": "./plugins/queue/server.d.ts",
      "default": "./plugins/queue/server.js"
    },
    "./plugins/groups": {
      "types": "./plugins/groups/server.d.ts",
      "default": "./plugins/groups/server.js"
    },
    "./plugins/groups/client": {
      "types": "./plugins/groups/client.d.ts",
      "default": "./plugins/groups/client.js"
    },
    "./plugins/lock": {
      "types": "./plugins/lock/server.d.ts",
      "default": "./plugins/lock/server.js"
    },
    "./plugins/session": {
      "types": "./plugins/session/server.d.ts",
      "default": "./plugins/session/server.js"
    },
    "./plugins/dedup": {
      "types": "./plugins/dedup/server.d.ts",
      "default": "./plugins/dedup/server.js"
    }
  },
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "upgrade-response.js",
    "testing.js",
    "testing.d.ts",
    "client.js",
    "client.d.ts",
    "vite.js",
    "vite.d.ts",
    "files",
    "plugins",
    "LICENSE",
    "README.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.js",
    "test:coverage": "node scripts/coverage.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "uWebSockets.js": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rollup": "^4.0.0"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "adapter",
    "uwebsockets",
    "uws",
    "performance",
    "websocket"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "c8": "^11.0.0",
    "polka": "^0.5.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.67.0"
  }
}
